{
  "$schema": "https://design-tokens.org/schema.json",
  "description": "Spacing tokens for the design system",
  "lastUpdated": "2026-02-16",
  
  "space": {
    "0":   { "value": "0",      "px": "0px",   "description": "No spacing" },
    "px":  { "value": "1px",    "px": "1px",   "description": "Hairline" },
    "0.5": { "value": "0.125rem", "px": "2px",  "description": "Minimal" },
    "1":   { "value": "0.25rem",  "px": "4px",  "description": "Tight" },
    "1.5": { "value": "0.375rem", "px": "6px",  "description": "Extra small" },
    "2":   { "value": "0.5rem",   "px": "8px",  "description": "Small" },
    "2.5": { "value": "0.625rem", "px": "10px", "description": "Small-medium" },
    "3":   { "value": "0.75rem",  "px": "12px", "description": "Medium-small" },
    "3.5": { "value": "0.875rem", "px": "14px", "description": "Medium" },
    "4":   { "value": "1rem",     "px": "16px", "description": "Base unit" },
    "5":   { "value": "1.25rem",  "px": "20px", "description": "Medium-large" },
    "6":   { "value": "1.5rem",   "px": "24px", "description": "Large" },
    "7":   { "value": "1.75rem",  "px": "28px", "description": "Large+" },
    "8":   { "value": "2rem",     "px": "32px", "description": "Extra large" },
    "9":   { "value": "2.25rem",  "px": "36px", "description": "Extra large+" },
    "10":  { "value": "2.5rem",   "px": "40px", "description": "2XL" },
    "11":  { "value": "2.75rem",  "px": "44px", "description": "2XL+" },
    "12":  { "value": "3rem",     "px": "48px", "description": "3XL" },
    "14":  { "value": "3.5rem",   "px": "56px", "description": "4XL" },
    "16":  { "value": "4rem",     "px": "64px", "description": "5XL" },
    "20":  { "value": "5rem",     "px": "80px", "description": "6XL" },
    "24":  { "value": "6rem",     "px": "96px", "description": "7XL" },
    "28":  { "value": "7rem",     "px": "112px", "description": "8XL" },
    "32":  { "value": "8rem",     "px": "128px", "description": "9XL" }
  },
  
  "semanticSpacing": {
    "page": {
      "paddingX": { "mobile": "4", "tablet": "6", "desktop": "8", "description": "Horizontal page padding" },
      "paddingY": { "mobile": "6", "tablet": "8", "desktop": "12", "description": "Vertical page padding" },
      "maxWidth": { "value": "1280px", "description": "Maximum content width" }
    },
    "section": {
      "gap": { "mobile": "12", "tablet": "16", "desktop": "20", "description": "Space between major sections" },
      "paddingY": { "mobile": "12", "tablet": "16", "desktop": "24", "description": "Vertical section padding" }
    },
    "card": {
      "padding": { "mobile": "4", "tablet": "6", "desktop": "6", "description": "Internal card padding" },
      "gap": { "value": "5", "description": "Space between cards in a grid" }
    },
    "stack": {
      "xs": { "value": "1", "description": "Tightest stack spacing" },
      "sm": { "value": "2", "description": "Small stack spacing" },
      "md": { "value": "4", "description": "Medium stack spacing" },
      "lg": { "value": "6", "description": "Large stack spacing" },
      "xl": { "value": "8", "description": "Extra large stack spacing" }
    },
    "inline": {
      "xs": { "value": "1", "description": "Tightest inline spacing" },
      "sm": { "value": "2", "description": "Small inline spacing" },
      "md": { "value": "3", "description": "Medium inline spacing" },
      "lg": { "value": "4", "description": "Large inline spacing" }
    },
    "form": {
      "fieldGap": { "value": "4", "description": "Space between form fields" },
      "labelGap": { "value": "1.5", "description": "Space between label and input" },
      "inputPaddingX": { "value": "3", "description": "Horizontal input padding" },
      "inputPaddingY": { "value": "2", "description": "Vertical input padding" }
    }
  },
  
  "borderRadius": {
    "none": { "value": "0",        "description": "Sharp corners" },
    "sm":   { "value": "0.125rem", "px": "2px", "description": "Subtle rounding" },
    "md":   { "value": "0.375rem", "px": "6px", "description": "Default rounding" },
    "lg":   { "value": "0.5rem",   "px": "8px", "description": "Medium rounding" },
    "xl":   { "value": "0.75rem",  "px": "12px", "description": "Large rounding" },
    "2xl":  { "value": "1rem",     "px": "16px", "description": "Extra large rounding" },
    "3xl":  { "value": "1.5rem",   "px": "24px", "description": "Pill-like rounding" },
    "full": { "value": "9999px",  "description": "Fully rounded (circles, pills)" }
  },
  
  "shadows": {
    "none": { "value": "none", "description": "No shadow" },
    "sm":   { "value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "description": "Subtle lift" },
    "md":   { "value": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)", "description": "Default elevation" },
    "lg":   { "value": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)", "description": "Raised elements" },
    "xl":   { "value": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)", "description": "Modals, popovers" },
    "2xl":  { "value": "0 25px 50px -12px rgb(0 0 0 / 0.25)", "description": "Maximum elevation" },
    "inner": { "value": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)", "description": "Inset shadow" }
  }
}
